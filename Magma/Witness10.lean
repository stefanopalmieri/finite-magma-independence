  Lower bound: 10 distinct elements need N ≥ 10 (counting).
  Upper bound: this witness.

Table generated by Z3 SAT solver, verified independently.
-/

set_option autoImplicit false

namespace KripkeWall

-- ═══════════════════════════════════════════════════════════════════
-- The N=10 R+D+H witness
-- ═══════════════════════════════════════════════════════════════════

private def rawW10 : Nat → Nat → Nat
  | 0, _ => 0
  | 1, _ => 1
  | 2, 0 => 3 | 2, 1 => 3 | 2, 2 => 4 | 2, 3 => 3 | 2, 4 => 7 | 2, 5 => 5 | 2, 6 => 9 | 2, 7 => 6 | 2, 8 => 8 | 2, 9 => 2
  | 3, 0 => 0 | 3, 1 => 1 | 3, 2 => 9 | 3, 3 => 3 | 3, 4 => 2 | 3, 5 => 5 | 3, 6 => 7 | 3, 7 => 4 | 3, 8 => 8 | 3, 9 => 6
  | 4, 0 => 0 | 4, 1 => 0 | 4, 2 => 1 | 4, 3 => 1 | 4, 4 => 1 | 4, 5 => 0 | 4, 6 => 0 | 4, 7 => 0 | 4, 8 => 1 | 4, 9 => 1
  | 5, 0 => 2 | 5, 1 => 2 | 5, 2 => 7 | 5, 3 => 2 | 5, 4 => 8 | 5, 5 => 9 | 5, 6 => 4 | 5, 7 => 3 | 5, 8 => 4 | 5, 9 => 2
  | 6, 0 => 0 | 6, 1 => 0 | 6, 2 => 6 | 6, 3 => 4 | 6, 4 => 8 | 6, 5 => 7 | 6, 6 => 3 | 6, 7 => 3 | 6, 8 => 4 | 6, 9 => 9
  | 7, 0 => 2 | 7, 1 => 2 | 7, 2 => 6 | 7, 3 => 4 | 7, 4 => 8 | 7, 5 => 9 | 7, 6 => 4 | 7, 7 => 3 | 7, 8 => 4 | 7, 9 => 9
  | 8, 0 => 2 | 8, 1 => 2 | 8, 2 => 4 | 8, 3 => 8 | 8, 4 => 4 | 8, 5 => 3 | 8, 6 => 4 | 8, 7 => 4 | 8, 8 => 8 | 8, 9 => 9
  | 9, 0 => 3 | 9, 1 => 4 | 9, 2 => 7 | 9, 3 => 3 | 9, 4 => 9 | 9, 5 => 2 | 9, 6 => 2 | 9, 7 => 9 | 9, 8 => 2 | 9, 9 => 3
  | _, _ => 0

private theorem rawW10_bound (a b : Fin 10) : rawW10 a.val b.val < 10 := by
  revert a b; native_decide

def dotW10 (a b : Fin 10) : Fin 10 := ⟨rawW10 a.val b.val, rawW10_bound a b⟩

-- ═══════════════════════════════════════════════════════════════════
-- Capability R: FaithfulRetractMagma (self-simulation infrastructure)
-- ═══════════════════════════════════════════════════════════════════

/-- The N=10 witness is a FaithfulRetractMagma with Q=2, E=3. -/
def witness10_frm : FaithfulRetractMagma 10 where
  dot := dotW10
  zero₁ := 0
  zero₂ := 1
  sec := 2
  ret := 3
  zero₁_left := by native_decide
  zero₂_left := by native_decide
  zeros_distinct := by native_decide
