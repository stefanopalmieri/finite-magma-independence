-- ═══════════════════════════════════════════════════════════════════
-- Capability H: Branch + Compose + Inert + Y (self-hosting)
-- ═══════════════════════════════════════════════════════════════════

/-- Branch: ρ(7)·x = f(5)·x when τ(4)·x = 0, else ρ·x = g(6)·x. -/
theorem witness10_branch :
    ∀ x : Fin 10, x ≠ (0 : Fin 10) → x ≠ (1 : Fin 10) →
      (dotW10 4 x = 0 → dotW10 7 x = dotW10 5 x) ∧
      (dotW10 4 x ≠ 0 → dotW10 7 x = dotW10 6 x) := by
  native_decide

/-- Inert: g(6) maps core away from absorbers. -/
theorem witness10_inert :
    ∀ x : Fin 10, x ≠ (0 : Fin 10) → x ≠ (1 : Fin 10) →
      dotW10 6 x ≠ 0 ∧ dotW10 6 x ≠ 1 := by
  native_decide

/-- Compose: η(8)·x = ρ(7)·(g(6)·x) on core. -/
theorem witness10_compose :
    ∀ x : Fin 10, x ≠ (0 : Fin 10) → x ≠ (1 : Fin 10) →
      dotW10 8 x = dotW10 7 (dotW10 6 x) := by
  native_decide

/-- Y fixed-point: Y(9)·ρ(7) = ρ·(Y·ρ), Y·ρ ∈ core. -/
theorem witness10_y_fixpoint :
    dotW10 9 7 = dotW10 7 (dotW10 9 7) ∧ (dotW10 9 7).val ≥ 2 := by
  native_decide

-- ═══════════════════════════════════════════════════════════════════
-- Tight bound theorem
-- ═══════════════════════════════════════════════════════════════════

/-- **Tight bound**: All three capabilities coexist at N=10.
    Combined with the trivial lower bound (10 distinct elements ⇒ N ≥ 10),
    this gives: R+D+H with distinct roles is satisfiable iff N ≥ 10. -/
theorem sdh_witness_10 :
    -- S: FaithfulRetractMagma exists
    ∃ (_ : FaithfulRetractMagma 10),
    -- D: DichotomicRetractMagma exists (Kripke holds)
    ∃ (_ : DichotomicRetractMagma 10),
    -- H: Branch + Compose + Inert + Y all hold
    (∀ x : Fin 10, x ≠ (0 : Fin 10) → x ≠ (1 : Fin 10) →
      (dotW10 4 x = 0 → dotW10 7 x = dotW10 5 x) ∧
      (dotW10 4 x ≠ 0 → dotW10 7 x = dotW10 6 x)) ∧
    (∀ x : Fin 10, x ≠ (0 : Fin 10) → x ≠ (1 : Fin 10) →
      dotW10 8 x = dotW10 7 (dotW10 6 x)) ∧
    (dotW10 9 7 = dotW10 7 (dotW10 9 7) ∧ (dotW10 9 7).val ≥ 2) :=
  ⟨witness10_frm, witness10_drm, witness10_branch, witness10_compose, witness10_y_fixpoint⟩

end KripkeWall
